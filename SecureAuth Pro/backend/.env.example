NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://localhost:27017/authentication_system

# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<replace-with-strong-random-secret>
JWT_REFRESH_SECRET=<replace-with-strong-random-secret>

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

CLIENT_ORIGIN=http://localhost:5173

CSRF_SECRET=<replace-with-strong-random-secret>
